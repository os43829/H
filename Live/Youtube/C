#!/bin/bash

trap "echo 'Stopped safely'; pkill ffmpeg; exit 0" SIGINT SIGTERM

# ======================
# SAVE FILES
# ======================
path_file=".videopath"
key_file=".streamkey"

# ======================
# RTMP SERVERS
# ======================
RTMPS=(
"rtmps://a.rtmp.youtube.com/live2"
"rtmps://b.rtmp.youtube.com/live2"
"rtmps://c.rtmp.youtube.com/live2"
)

# ======================
# BITRATES (LOCKED)
# ======================
BITRATES=(3500k 3000k 2500k)
BR_INDEX=0

MIN_STABLE_TIME=30   # sec
RETRY_DELAY=10

# ======================
# VIDEO INPUT
# ======================
read -p "Enter video file name or full path: " input_video

if [[ "$input_video" != /* ]]; then
  if [ -f "$path_file" ]; then
    input_video="$(cat "$path_file")/$input_video"
  else
    echo "❌ First time full path dijiye"
    exit 1
  fi
else
  echo "$(dirname "$input_video")" > "$path_file"
fi

[ ! -f "$input_video" ] && echo "❌ Video not found" && exit 1

# ======================
# STREAM KEY
# ======================
if [ -f "$key_file" ]; then
  read -p "Enter stream key (Enter = last): " STREAM_KEY
  STREAM_KEY="${STREAM_KEY:-$(cat "$key_file")}"
else
  read -p "Enter stream key: " STREAM_KEY
fi
echo "$STREAM_KEY" > "$key_file"

# ======================
# MAIN LOOP
# ======================
while true; do
  for RTMP in "${RTMPS[@]}"; do

    BITRATE="${BITRATES[$BR_INDEX]}"
    FULL_URL="$RTMP/$STREAM_KEY"

    echo "=================================="
    echo " RTMP    : $RTMP"
    echo " BITRATE : $BITRATE"
    echo "=================================="

    START_TIME=$(date +%s)

    ffmpeg -re -stream_loop -1 \
      -thread_queue_size 1024 \
      -i "$input_video" \
      -c:v libx264 -preset veryfast -tune zerolatency \
      -b:v $BITRATE -maxrate $BITRATE -bufsize 7000k \
      -x264opts keyint=60:min-keyint=60:no-scenecut \
      -vf "scale=720:1280,fps=30" \
      -pix_fmt yuv420p \
      -c:a aac -b:a 128k -ar 44100 \
      -f flv "$FULL_URL"

    EXIT_CODE=$?
    END_TIME=$(date +%s)
    RUN_TIME=$((END_TIME - START_TIME))

    echo "FFmpeg exited after $RUN_TIME sec (code $EXIT_CODE)"

    # ======================
    # EARLY CRASH LOGIC
    # ======================
    if (( RUN_TIME < MIN_STABLE_TIME )); then
      echo "❌ Early crash detected"

      if (( BR_INDEX < ${#BITRATES[@]}-1 )); then
        ((BR_INDEX++))
        echo "⬇ Bitrate dropped to ${BITRATES[$BR_INDEX]}"
      else
        echo "⚠ Already at lowest bitrate"
      fi
    else
      echo "✅ Stream was stable → bitrate unchanged"
    fi

    echo "Reconnecting in $RETRY_DELAY sec..."
    sleep $RETRY_DELAY

  done
done
